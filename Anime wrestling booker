<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anime Wrestling Booker</title>
    <style>
        :root { 
            --neon-blue: #00f2ff; 
            --neon-gold: #ffd700; 
            --neon-green: #00ff88;
            --neon-red: #ff0044;
            --bg: #0a0a0a; 
        }
        * { box-sizing: border-box; }
        body { 
            background: var(--bg); 
            color: white; 
            font-family: 'Courier New', monospace; 
            margin: 0; 
            padding-bottom: 100px;
        }
        .header { 
            text-align: center; 
            padding: 15px; 
            border-bottom: 2px solid var(--neon-blue);
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }
        .header-top { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; }
        .header-top h2 { margin: 0; flex: 1; }
        .coins { 
            background: var(--neon-gold); 
            color: black; 
            padding: 5px 10px; 
            border-radius: 4px; 
            font-weight: bold;
        }
        #calendar { font-size: 14px; color: var(--neon-blue); margin-top: 10px; }
        
        .roster-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 10px; 
            padding: 10px; 
        }
        .card { 
            border: 2px solid #333; 
            border-radius: 8px; 
            padding: 5px; 
            text-align: center; 
            background: #1a1a1a; 
            position: relative; 
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .card:hover { 
            border-color: var(--neon-blue); 
            box-shadow: 0 0 10px rgba(0, 242, 255, 0.3);
        }
        .card.champion { 
            border: 3px solid var(--neon-gold); 
            box-shadow: 0 0 10px var(--neon-gold); 
        }
        .card.selected { 
            border: 3px solid var(--neon-green); 
            box-shadow: 0 0 15px var(--neon-green);
        }
        .card img { 
            width: 100%; 
            height: auto; 
            image-rendering: pixelated; 
            background: #000; 
            border-radius: 4px;
        }
        .badge { 
            position: absolute; 
            top: 5px; 
            right: 5px; 
            padding: 2px 5px; 
            font-size: 10px; 
            border-radius: 4px; 
        }
        .face { background: #00ff88; color: black; }
        .heel { background: #ff0044; color: white; }
        
        .nav { 
            position: fixed; 
            bottom: 0; 
            width: 100%; 
            background: #111; 
            display: flex; 
            justify-content: space-around; 
            padding: 10px 0; 
            border-top: 2px solid var(--neon-blue); 
            gap: 5px;
        }
        .nav button { 
            flex: 1; 
            background: #222; 
            color: white; 
            border: 1px solid var(--neon-blue); 
            padding: 12px; 
            cursor: pointer; 
            font-weight: bold;
        }
        .nav button.active { 
            background: var(--neon-blue); 
            color: black; 
        }
        
        .filter-bar { 
            display: flex; 
            overflow-x: auto; 
            padding: 10px; 
            gap: 10px; 
            background: #151515; 
        }
        button { 
            background: #222; 
            color: white; 
            border: 1px solid var(--neon-blue); 
            padding: 8px 12px; 
            cursor: pointer; 
            border-radius: 4px;
            transition: all 0.2s ease;
        }
        button:hover { 
            background: #333; 
            box-shadow: 0 0 8px var(--neon-blue);
        }
        button:disabled { 
            opacity: 0.5; 
            border-color: #555; 
            cursor: not-allowed;
        }
        button.active { 
            background: var(--neon-blue); 
            color: black; 
            border-color: var(--neon-blue);
        }
        
        .tab-content { 
            padding: 10px; 
            display: none; 
        }
        .tab-content.active { 
            display: block; 
        }
        .hidden { display: none; }
        
        /* BOOKING ENGINE STYLES */
        .booking-section { 
            margin-bottom: 20px; 
            border: 2px solid var(--neon-blue); 
            border-radius: 8px; 
            padding: 15px; 
            background: #1a1a1a;
        }
        .booking-title { 
            font-size: 16px; 
            font-weight: bold; 
            color: var(--neon-gold); 
            margin-bottom: 10px;
        }
        .match-slot { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 10px; 
            background: #222; 
            border: 1px solid #333; 
            margin-bottom: 8px; 
            border-radius: 4px;
        }
        .match-slot-label { 
            font-weight: bold; 
            color: var(--neon-blue); 
            min-width: 100px; 
        }
        .match-slot-fighters { 
            flex: 1; 
            text-align: center; 
            margin: 0 10px; 
            font-size: 12px;
        }
        .match-slot-btn { 
            padding: 6px 10px; 
            font-size: 11px; 
        }
        .title-checkbox { 
            display: flex; 
            align-items: center; 
            gap: 8px; 
            margin-top: 5px;
        }
        .title-checkbox input { 
            cursor: pointer; 
        }
        
        .wrestler-selector { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 10px; 
            max-height: 400px; 
            overflow-y: auto; 
            padding: 10px; 
            background: #151515; 
            border-radius: 4px;
        }
        .selector-card { 
            border: 2px solid #333; 
            padding: 8px; 
            text-align: center; 
            cursor: pointer; 
            background: #1a1a1a;
            border-radius: 4px;
            transition: all 0.2s ease;
        }
        .selector-card:hover { 
            border-color: var(--neon-blue); 
            box-shadow: 0 0 10px rgba(0, 242, 255, 0.2);
        }
        .selector-card.unavailable { 
            opacity: 0.4; 
            cursor: not-allowed; 
            border-color: #555;
        }
        .selector-card img { 
            width: 100%; 
            height: auto; 
            border-radius: 3px;
        }
        
